# ---------------------------------------------------------------------------
# Banco de dados (Postgres / Supabase) — usado pelo Prisma
# ---------------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------------
# Autenticação — segredo para assinar/verificar os JWT de sessão
# ---------------------------------------------------------------------------
JWT_SECRET=

# ---------------------------------------------------------------------------
# Login social (Google OAuth 2.0)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Pagamentos / assinatura (Stripe)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# URL pública da aplicação (usada em redirects OAuth e Stripe Checkout).
# Em dev: http://localhost:3000 — em produção: a URL do deploy no Vercel.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
